generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Segment {
  SMB
  MID_MARKET
  ENTERPRISE
  STRATEGIC
}

enum Geography {
  NA_EAST
  NA_WEST
  EMEA
  APAC
}

enum AccountTier {
  TIER_3
  TIER_2
  TIER_1
  STRATEGIC
}

enum LifecycleStage {
  PROSPECT
  ENGAGED
  SALES_READY
  CUSTOMER
  NURTURE
}

enum AccountStatus {
  HEALTHY
  WATCH
  HOT
  AT_RISK
}

enum LeadStatus {
  NEW
  WORKING
  QUALIFIED
  NURTURING
  DISQUALIFIED
}

enum Temperature {
  COLD
  WARM
  HOT
  URGENT
}

enum SignalType {
  WEBSITE_VISIT
  PRICING_PAGE_VISIT
  HIGH_INTENT_PAGE_CLUSTER_VISIT
  FORM_FILL
  WEBINAR_REGISTRATION
  PRODUCT_SIGNUP
  PRODUCT_USAGE_MILESTONE
  EMAIL_REPLY
  MEETING_BOOKED
  MEETING_NO_SHOW
  THIRD_PARTY_INTENT_EVENT
  MANUAL_SALES_NOTE
  ACCOUNT_STATUS_UPDATE
}

enum SignalStatus {
  RECEIVED
  NORMALIZED
  MATCHED
  UNMATCHED
  ERROR
}

enum SignalCategory {
  WEB_ACTIVITY
  CONVERSION
  PRODUCT
  SALES_ENGAGEMENT
  SALES_ACTIVITY
  INTENT
  MANUAL
  ACCOUNT_CHANGE
}

enum SignalStrength {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum ScoreEntityType {
  ACCOUNT
  LEAD
}

enum ScoreComponent {
  FIT
  INTENT
  ENGAGEMENT
  RECENCY
  PRODUCT_USAGE
  MANUAL_PRIORITY
}

enum RoutingEntityType {
  LEAD
  ACCOUNT
}

enum RoutingDecisionType {
  NAMED_ACCOUNT_OWNER
  EXISTING_ACCOUNT_OWNER
  STRATEGIC_TIER_OVERRIDE
  TERRITORY_SEGMENT_RULE
  ROUND_ROBIN_POOL
  OPS_REVIEW_QUEUE
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  CALL
  EMAIL
  RESEARCH
  HANDOFF
  REVIEW
  ENRICH
  ESCALATION
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SlaStatus {
  ON_TRACK
  DUE_SOON
  OVERDUE
  BREACHED
  COMPLETED
  PAUSED
}

enum SlaEntityType {
  LEAD
  TASK
  ACCOUNT
}

enum SlaEventType {
  ASSIGNED
  STATE_CHANGED
  BREACHED
  MET
  RESOLVED
  ESCALATION_CREATED
}

enum ActionCategory {
  IMMEDIATE_RESPONSE
  ENRICHMENT
  HANDOFF
  RESEARCH
  NURTURE
  PAUSE
  ESCALATION
  PLANNING
  MANUAL
}

enum ActionType {
  CALL_WITHIN_15_MINUTES
  SEND_FOLLOW_UP_EMAIL
  ENRICH_MISSING_CONTACT_FIELDS
  HANDOFF_TO_AE
  RESEARCH_ACCOUNT
  ADD_TO_NURTURE_QUEUE
  PAUSE_ACTIVE_ACCOUNT
  ESCALATE_SLA_BREACH
  GENERATE_ACCOUNT_SUMMARY
  MANUAL_CUSTOM
}

enum AuditEventType {
  SIGNAL_INGESTED
  SIGNAL_NORMALIZED
  IDENTITY_RESOLVED
  SIGNAL_UNMATCHED_QUEUED
  SIGNAL_DUPLICATE_SKIPPED
  SIGNAL_INGEST_ERROR
  SCORE_UPDATED
  SCORE_RECOMPUTED
  SCORE_THRESHOLD_CROSSED
  SCORE_MANUAL_PRIORITY_OVERRIDDEN
  SIGNAL_ATTACHED_AND_RESCORED
  ROUTE_ASSIGNED
  ROUTING_FALLBACK_CAPACITY
  ROUTING_SENT_TO_OPS_REVIEW
  TASK_CREATED
  TASK_UPDATED
  ACTION_RECOMMENDATION_CREATED
  DUPLICATE_ACTION_PREVENTED
  ACTION_GENERATION_SKIPPED
  SLA_ASSIGNED
  SLA_BREACHED
  SLA_RESOLVED
  USER_OVERRIDE
  RULE_CONFIG_CHANGED
}

enum ScoreTriggerType {
  SIGNAL_INGESTED
  SIGNAL_ATTACHED
  MANUAL_PRIORITY_CHANGED
  RELATIONSHIP_CHANGED
  MANUAL_RECOMPUTE
}

model User {
  id                          String            @id
  name                        String
  email                       String            @unique
  role                        String
  team                        String
  geography                   Geography
  title                       String?
  avatarColor                 String?
  maxOpenHotLeads             Int               @default(3)
  maxDailyInboundAssignments  Int               @default(6)
  maxOpenTasks                Int               @default(12)
  ownedAccounts               Account[]         @relation("NamedOwner")
  accountPortfolio            Account[]         @relation("AccountOwner")
  assignedLeads               Lead[]            @relation("LeadOwner")
  ownedTasks                  Task[]            @relation("TaskOwner")
  actionRecommendations       ActionRecommendation[] @relation("RecommendationOwner")
  routingAssignments          RoutingDecision[] @relation("RoutingOwner")
  routingSecondaryAssignments RoutingDecision[] @relation("RoutingSecondaryOwner")
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
}

model Account {
  id                String            @id
  name              String
  domain            String            @unique
  segment           Segment
  industry          String
  geography         Geography
  employeeCount     Int
  annualRevenueBand String
  namedOwnerId      String?
  ownerId           String?
  accountTier       AccountTier
  lifecycleStage    LifecycleStage
  fitScore          Int
  intentScore       Int               @default(0)
  engagementScore   Int               @default(0)
  recencyScore      Int               @default(0)
  productUsageScore Int               @default(0)
  manualPriorityScore Int             @default(0)
  manualPriorityBoost Int             @default(0)
  manualPriorityNote String?
  manualPriorityUpdatedAt DateTime?
  overallScore      Int
  temperature       Temperature       @default(COLD)
  status            AccountStatus
  scoreBreakdownJson Json             @default("{}")
  scoreReasonCodesJson Json           @default("[]")
  scoreExplanationJson Json           @default("{}")
  scoreLastComputedAt DateTime?
  scoringVersion    String            @default("scoring/v1")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  namedOwner        User?             @relation("NamedOwner", fields: [namedOwnerId], references: [id])
  owner             User?             @relation("AccountOwner", fields: [ownerId], references: [id])
  contacts          Contact[]
  leads             Lead[]
  signals           SignalEvent[]
  tasks             Task[]
  actionRecommendations ActionRecommendation[]
  routingDecisions  RoutingDecision[]
  auditLogs         AuditLog[]
  scoreHistory      ScoreHistory[]
  slaEvents         SlaEvent[]

  @@index([segment, geography])
  @@index([overallScore])
  @@index([temperature, overallScore])
  @@index([namedOwnerId])
  @@index([ownerId])
}

model Contact {
  id          String      @id
  accountId   String
  firstName   String
  lastName    String
  email       String      @unique
  title       String
  department  String
  seniority   String
  phone       String?
  personaType String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  leads       Lead[]
  signals     SignalEvent[]

  @@index([accountId])
}

model Lead {
  id              String             @id
  accountId       String
  contactId       String?
  source          String
  inboundType     String
  currentOwnerId  String?
  status          LeadStatus
  fitScore        Int                @default(0)
  intentScore     Int                @default(0)
  engagementScore Int                @default(0)
  recencyScore    Int                @default(0)
  productUsageScore Int              @default(0)
  manualPriorityScore Int            @default(0)
  manualPriorityBoost Int            @default(0)
  manualPriorityNote String?
  manualPriorityUpdatedAt DateTime?
  score           Int
  temperature     Temperature
  scoreBreakdownJson Json            @default("{}")
  scoreReasonCodesJson Json          @default("[]")
  scoreExplanationJson Json          @default("{}")
  scoreLastComputedAt DateTime?
  scoringVersion  String             @default("scoring/v1")
  slaPolicyKey    String?
  slaPolicyVersion String?
  slaTargetMinutes Int?
  slaDeadlineAt   DateTime?
  slaStatus       SlaStatus?
  slaBreachedAt   DateTime?
  firstResponseAt DateTime?
  routedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  account         Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact         Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  currentOwner    User?              @relation("LeadOwner", fields: [currentOwnerId], references: [id], onDelete: SetNull)
  signals         SignalEvent[]
  routingDecisions RoutingDecision[]
  tasks           Task[]
  actionRecommendations ActionRecommendation[]
  scoreHistory    ScoreHistory[]
  auditLogs       AuditLog[]
  slaEvents       SlaEvent[]

  @@index([accountId])
  @@index([currentOwnerId])
  @@index([status, temperature])
  @@index([slaStatus, slaDeadlineAt])
}

model SignalEvent {
  id                    String         @id
  sourceSystem          String
  eventType             SignalType
  accountDomain         String?
  contactEmail          String?
  accountId             String?
  contactId             String?
  leadId                String?
  eventCategory         SignalCategory   @default(MANUAL)
  intentStrength        SignalStrength   @default(NONE)
  engagementStrength    SignalStrength   @default(NONE)
  payloadSummary        String           @default("")
  rawPayloadJson        Json
  normalizedPayloadJson Json
  identityResolutionCodesJson Json       @default("[]")
  occurredAt            DateTime
  receivedAt            DateTime
  dedupeKey             String         @unique
  status                SignalStatus
  errorMessage          String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @default(now()) @updatedAt
  account               Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact               Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead                  Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  triggeredScoreHistory ScoreHistory[] @relation("ScoreHistoryTriggerSignal")
  triggeredRoutingDecisions RoutingDecision[] @relation("RoutingTriggerSignal")
  triggeredTasks Task[] @relation("TaskTriggerSignal")
  triggeredActionRecommendations ActionRecommendation[] @relation("RecommendationTriggerSignal")

  @@index([accountId])
  @@index([leadId])
  @@index([accountId, occurredAt])
  @@index([accountId, occurredAt, status])
  @@index([contactId, occurredAt])
  @@index([status, createdAt])
  @@index([status, occurredAt])
  @@index([accountDomain])
  @@index([contactEmail])
}

model ScoreHistory {
  id                   String           @id
  entityType           ScoreEntityType
  entityId             String
  accountId            String?
  leadId               String?
  previousScore        Int
  newScore             Int
  delta                Int
  previousTemperature  Temperature
  newTemperature       Temperature
  componentBreakdownJson Json
  reasonCodesJson      Json
  explanationJson      Json
  triggerType          ScoreTriggerType
  triggerSignalId      String?
  triggerMetadataJson  Json?
  scoringVersion       String
  createdAt            DateTime         @default(now())
  account              Account?         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead                 Lead?            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  triggerSignal        SignalEvent?     @relation("ScoreHistoryTriggerSignal", fields: [triggerSignalId], references: [id], onDelete: SetNull)
  triggeredTasks       Task[]           @relation("TaskTriggerScoreHistory")
  triggeredActionRecommendations ActionRecommendation[] @relation("RecommendationTriggerScoreHistory")

  @@index([accountId, createdAt])
  @@index([leadId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([triggerSignalId, createdAt])
}

model RoutingDecision {
  id                  String              @id
  entityType          RoutingEntityType
  entityId            String
  leadId              String?
  accountId           String?
  policyVersion       String
  decisionType        RoutingDecisionType
  assignedOwnerId     String?
  secondaryOwnerId    String?
  assignedTeam        String?
  assignedQueue       String
  reasonCodesJson     Json                @default("[]")
  explanationJson     Json                @default("{}")
  slaTargetMinutes    Int?
  slaDueAt            DateTime?
  escalationPolicyKey String?
  triggerSignalId     String?
  createdAt           DateTime            @default(now())
  lead                Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  account             Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  assignedOwner       User?               @relation("RoutingOwner", fields: [assignedOwnerId], references: [id], onDelete: SetNull)
  secondaryOwner      User?               @relation("RoutingSecondaryOwner", fields: [secondaryOwnerId], references: [id], onDelete: SetNull)
  triggerSignal       SignalEvent?        @relation("RoutingTriggerSignal", fields: [triggerSignalId], references: [id], onDelete: SetNull)
  generatedTasks      Task[]              @relation("TaskTriggerRoutingDecision")
  generatedRecommendations ActionRecommendation[] @relation("RecommendationTriggerRoutingDecision")

  @@index([entityType, entityId, createdAt])
  @@index([accountId, createdAt])
  @@index([leadId, createdAt])
  @@index([assignedOwnerId, createdAt])
  @@index([secondaryOwnerId, createdAt])
  @@index([triggerSignalId, createdAt])
}

model Task {
  id                       String       @id
  leadId                   String?
  accountId                String?
  ownerId                  String?
  taskType                 TaskType
  actionType               ActionType   @default(MANUAL_CUSTOM)
  actionCategory           ActionCategory @default(MANUAL)
  priority                 TaskPriority
  isSlaTracked             Boolean      @default(false)
  slaPolicyKey             String?
  slaPolicyVersion         String?
  slaTargetMinutes         Int?
  slaStatus                SlaStatus?
  slaBreachedAt            DateTime?
  dueAt                    DateTime
  status                   TaskStatus
  title                    String
  description              String
  sourceReasonCodesJson    Json         @default("[]")
  explanationJson          Json         @default("{}")
  dedupeKey                String?      @unique
  triggerSignalId          String?
  triggerRoutingDecisionId String?
  triggerScoreHistoryId    String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @default(now()) @updatedAt
  completedAt              DateTime?
  lead                     Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  account                  Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  owner                    User?        @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  triggerSignal            SignalEvent? @relation("TaskTriggerSignal", fields: [triggerSignalId], references: [id], onDelete: SetNull)
  triggerRoutingDecision   RoutingDecision? @relation("TaskTriggerRoutingDecision", fields: [triggerRoutingDecisionId], references: [id], onDelete: SetNull)
  triggerScoreHistory      ScoreHistory? @relation("TaskTriggerScoreHistory", fields: [triggerScoreHistoryId], references: [id], onDelete: SetNull)
  slaEvents                SlaEvent[]

  @@index([accountId])
  @@index([leadId])
  @@index([ownerId])
  @@index([status, dueAt])
  @@index([isSlaTracked, slaStatus, dueAt])
  @@index([triggerSignalId])
  @@index([triggerRoutingDecisionId])
  @@index([triggerScoreHistoryId])
}

model ActionRecommendation {
  id                       String         @id
  leadId                   String?
  accountId                String?
  recommendationType       ActionType
  actionCategory           ActionCategory
  severity                 TaskPriority
  title                    String
  summary                  String
  suggestedOwnerId         String?
  suggestedQueue           String?
  sourceReasonCodesJson    Json           @default("[]")
  explanationJson          Json           @default("{}")
  dedupeKey                String?        @unique
  triggerSignalId          String?
  triggerRoutingDecisionId String?
  triggerScoreHistoryId    String?
  createdAt                DateTime       @default(now())
  lead                     Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  account                  Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  suggestedOwner           User?          @relation("RecommendationOwner", fields: [suggestedOwnerId], references: [id], onDelete: SetNull)
  triggerSignal            SignalEvent?   @relation("RecommendationTriggerSignal", fields: [triggerSignalId], references: [id], onDelete: SetNull)
  triggerRoutingDecision   RoutingDecision? @relation("RecommendationTriggerRoutingDecision", fields: [triggerRoutingDecisionId], references: [id], onDelete: SetNull)
  triggerScoreHistory      ScoreHistory?  @relation("RecommendationTriggerScoreHistory", fields: [triggerScoreHistoryId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([leadId, createdAt])
  @@index([suggestedOwnerId, createdAt])
  @@index([triggerSignalId])
  @@index([triggerRoutingDecisionId])
  @@index([triggerScoreHistoryId])
}

model AuditLog {
  id          String         @id
  eventType   AuditEventType
  actorType   String
  actorName   String
  entityType  String
  entityId    String
  accountId   String?
  leadId      String?
  beforeState Json?
  afterState  Json?
  explanation String
  createdAt   DateTime       @default(now())
  account     Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  lead        Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([leadId, createdAt])
  @@index([eventType, createdAt])
}

model SlaEvent {
  id            String        @id
  entityType    SlaEntityType
  entityId      String
  leadId        String?
  taskId        String?
  accountId     String?
  eventType     SlaEventType
  policyVersion String?
  policyKey     String?
  targetMinutes Int?
  dueAt         DateTime?
  breachedAt    DateTime?
  resolvedAt    DateTime?
  explanationJson Json       @default("{}")
  createdAt     DateTime      @default(now())
  lead          Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  task          Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  account       Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([leadId, createdAt])
  @@index([taskId, createdAt])
  @@index([eventType, createdAt])
}

model RuleConfig {
  id         String   @id
  ruleType   String
  version    String
  isActive   Boolean  @default(false)
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ruleType, isActive])
}
